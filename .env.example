ROS_DISTRO=jazzy
ORBBEC_REF=v2-main
ORBBEC_IMAGE=ghcr.io/bjoernellens1/orbbec-ros2-jazzy:latest
# OrbbecViewer (standalone GUI) build args. Leave ORBBEC_VIEWER_URL empty to skip.
ORBBEC_VIEWER_URL=https://github.com/orbbec/OrbbecSDK/releases/download/v1.10.27/OrbbecViewer_v1.10.27_202509260133_linux_x64_release.zip
ORBBEC_VIEWER_VERSION=1.10.27
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
FASTDDS_BUILTIN_TRANSPORTS=LARGE_DATA

# Optional: bind-mount a single USB bus into the container instead of the whole USB tree.
# Find it on the host with: lsusb -t  (look for the Orbbec device, e.g. "Bus 02 ...")
# Example: ORBBEC_USB_DEVICE=2  -> mounts /dev/bus/usb/002 only.
# Leave empty to keep the default whole-tree passthrough (works out of the box).
ORBBEC_USB_DEVICE=
